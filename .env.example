# MCP server
MCP_PORT=3010
HOST_PORT=3010
MCP_ACCESS_TOKEN=change-me

# Service base URLs
HOME_ASSISTANT_BASE_URL=https://iot.vmhq.cl
MINIFLUX_BASE_URL=https://miniflux.vmhq.cl
KARAKEEP_BASE_URL=https://karakeep.vmhq.cl
SEARXNG_BASE_URL=https://searx.vmhq.cl
PROXMOX_BASE_URL=https://pve.vmhq.cl
MEMOS_BASE_URL=https://memos.vmhq.cl

# Service credentials
HOME_ASSISTANT_TOKEN=
MINIFLUX_TOKEN=
KARAKEEP_TOKEN=
SEARXNG_TOKEN=
PROXMOX_TOKEN=
MEMOS_TOKEN=

# Optional auth/header overrides
# Miniflux can use X-Auth-Token or Authorization: Bearer depending on your setup.
MINIFLUX_AUTH_MODE=x-auth-token
# Proxmox sends Authorization as: PVEAPIToken=USER@REALM!TOKENID=SECRET
PROXMOX_AUTH_PREFIX=PVEAPIToken=

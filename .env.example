# MCP server
MCP_PORT=3010
HOST_PORT=3010
MCP_PUBLIC_URL=https://mcp.example.com
MCP_ICON_URL=https://cdn.jsdelivr.net/gh/selfhst/icons/png/mcphub.png
MCP_ACCESS_TOKEN=change-me

# Service base URLs
# Leave a URL empty to disable that service.
HOME_ASSISTANT_BASE_URL=https://home-assistant.example.com
MINIFLUX_BASE_URL=https://miniflux.example.com
KARAKEEP_BASE_URL=https://karakeep.example.com
SEARXNG_BASE_URL=https://searxng.example.com
PROXMOX_BASE_URL=https://proxmox.example.com
MEMOS_BASE_URL=https://memos.example.com
NEXTDNS_BASE_URL=https://api.nextdns.io

# Perplexity via OpenRouter
# Set OPENROUTER_API_KEY to enable Perplexity search (sonar-pro, sonar-reasoning-pro, sonar-deep-research).
# OPENROUTER_BASE_URL defaults to https://openrouter.ai/api/v1 — only override if using a proxy.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Service credentials
HOME_ASSISTANT_TOKEN=
MINIFLUX_TOKEN=
KARAKEEP_TOKEN=
MEMOS_TOKEN=
NEXTDNS_API_KEY=
NEXTDNS_PROFILE_ID=39f768

# Proxmox API token
# Token ID format: USER@REALM!TOKENID
PROXMOX_TOKEN_ID=root@pam!mcp
PROXMOX_TOKEN_SECRET=

# Optional auth/header overrides
# Miniflux can use X-Auth-Token or Authorization: Bearer depending on your setup.
MINIFLUX_AUTH_MODE=x-auth-token

# Optional security settings
# Restrict CORS to a specific origin (e.g. https://claude.ai). Defaults to * if unset.
# MCP_CORS_ORIGIN=https://claude.ai
# Path for persisting OAuth state (clients + tokens) between restarts.
# When using Docker, this path is inside the container — matches the ./data:/app/data volume.
# MCP_OAUTH_STATE_PATH=/app/data/oauth-state.json
